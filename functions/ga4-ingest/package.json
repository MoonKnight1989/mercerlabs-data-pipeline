{
  "name": "ga4-ingest",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "gcp-build": "npm run build",
    "check": "tsc --noEmit && eslint . && vitest run",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "gcloud functions deploy ga4Ingest --gen2 --runtime=nodejs22 --trigger-http --source=. --entry-point=ga4Ingest --region=us-east1 --project=mercer-labs-488707 --memory=1Gi --timeout=540s --no-allow-unauthenticated"
  },
  "dependencies": {
    "@google-analytics/data": "^4.8.0",
    "@google-cloud/bigquery": "^7.9.0",
    "@google-cloud/functions-framework": "^3.4.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "@types/node": "^20.0.0",
    "vitest": "^2.0.0"
  }
}
