{
  "name": "daily-email-digest",
  "version": "2.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "gcp-build": "npm run build",
    "check": "tsc --noEmit",
    "deploy": "gcloud functions deploy dailyEmailDigest --gen2 --runtime=nodejs22 --trigger-http --source=. --entry-point=dailyEmailDigest --region=us-east1 --project=mercer-labs-488707 --memory=256Mi --timeout=120s --no-allow-unauthenticated"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.9.0",
    "@google-cloud/functions-framework": "^3.4.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.6.0"
  }
}
